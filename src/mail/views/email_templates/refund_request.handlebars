<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{type}} - Wallet Transaction | HB</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

        /* Body and base */
        body,
        html {
            margin: 0;
            padding: 0;
            background-color: black;
            font-family: 'Roboto', sans-serif;
            color: black;
            width: 100vw;
        }

        * {
            box-sizing: border-box;
        }

        /* Outer container */
        .container {
            background-color: black;
            max-width: 1080px;
            margin: 20px auto 0 auto;
            width: 100%;
        }

        /* Content wrapper */
        .content__wrapper {
            background-color: #121212;
            background-size: cover;
            background-repeat: no-repeat;
            padding: 20px;
            min-height: 70vh;
        }

        /* White card */
        .card {
            background-color: white;
            padding: 10px 30px;
            max-width: 600px;
            margin: 10px auto;
            box-shadow: 1px 1px 1px grey;
        }

        .mt-20 {
            margin-top: 20px !important;
        }

        /* Header text styling */
        .header__text {
            border: 1px solid black;
            padding: 5px;
            border-radius: 2px;
            font-weight: bold;
            width: 80%;
            margin: 40px auto 20px auto;
            text-align: center;
            font-size: 16px;
            letter-spacing: 0.5px;
            background-color: white;
            color: black;
        }

        p {
            margin: 5px 0;
            padding: 0;
            font-size: 14px;
            line-height: 1.5;
            color: black;
        }

        .text__center {
            text-align: center;
        }

        .transaction-amount {
            font-size: 24px;
            font-weight: bold;
            margin: 15px 0;
        }

        .footer-card a,
        .unsubscribe a {
            color: #4c83ee;
            text-decoration: underline;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="content__wrapper">

            <div class="card">
                <div class="header__text">
                    REFUND REQUESTED
                </div>

                <p class="text__center">Customer has requested for refund. Details below:</p>

                <div class="text__center" style="font-size: 14px; color: black; margin-top: 20px;">
                    <p><strong>Email:</strong> {{customerEmail}}</p>
                    <p><strong>BTC Address:</strong> {{btcAddress}}</p>
                    <p><strong>Refund Amount:</strong> {{creditAmount}}</p>
                    {{#if description}}
                    <p><strong>Description:</strong> {{description}}</p>
                    {{/if}}
                </div>

                <div class="text__center" style="margin: 25px 0;">
                    <a href="{{link}}"
                        style="text-decoration: underline; color: #007bff; text-align: center; font-weight: 500;">
                        GO TO VIEW DETAILS
                    </a>
                </div>
            </div>

            {{!-- Footer with Assistance and Unsubscribe --}}
            {{#if footer.isFooterShow}}
            <div class="card mt-20 text__center">
                <h3>Need Help?</h3>
                <p><b>Email:</b> {{footer.email}}</p>
                <br />

                <div>
                    <a href="{{unsubscribe_link}}" class="text__center"
                        style="text-decoration: underline; font-weight: bold; font-size: 1.2rem; display: block; color:#4c83ee;">
                        Unsubscribe</a> from mailing list.
                </div>
            </div>
            {{/if}}

        </div>
    </div>
</body>

</html>